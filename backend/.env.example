# ─── SERVIDOR ────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development   # Cambiar a "production" en el servidor real

# ─── BASE DE DATOS ────────────────────────────────────────────────────────────
# Formato: postgresql://USUARIO:CONTRASEÑA@HOST:PUERTO/NOMBRE_DB
# En producción agregar: ?sslmode=require
DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/nombre_db

# ─── AUTENTICACIÓN ────────────────────────────────────────────────────────────
# Clave secreta para proteger la API. Mínimo 32 caracteres aleatorios.
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_SECRET_KEY=

# ─── CORS ─────────────────────────────────────────────────────────────────────
# URL exacta del frontend (sin slash al final)
FRONTEND_URL=http://localhost:5173
